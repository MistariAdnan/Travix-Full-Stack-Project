
<style>
.navbar {
    border-bottom: 1px solid #eee;
}

.navbar-brand {
    letter-spacing: 0.5px;
}

.search-box {
    width: 45%;
}

.search-input {
    border-radius: 50px;
    padding: 10px 18px;
    border: 1px solid #ddd;
}

.search-btn {
    background: #ff385c;
    color: white;
    border-radius: 50px;
    padding: 10px 18px;
    margin-left: 8px;
}

.search-btn:hover {
    background: #e61e4d;
    color: white;
}

@media(max-width:768px){
    .search-box{
        width:100%;
        margin-top:10px;
    }
}
</style>

<nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm sticky-top px-4">
    <div class="container-fluid">

        <a class="navbar-brand fw-bold fs-4 text-danger" href="/listings">
            <i class="fa-solid fa-house me-2"></i>Travix
        </a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavAltMarkup">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarNavAltMarkup">

            <div class="navbar-nav">
                <!-- <a class="nav-link fw-semibold" href="/listings">Explore</a> -->
            </div>

            <form class="d-flex mx-auto search-box" action="/listings" method="GET">

                <input
                    class="form-control search-input"
                    type="search"
                    name="search"
                    placeholder="Search city, country, property..."
                    value="<%= typeof search !== 'undefined' ? search : '' %>"
                >

                <button class="btn search-btn" type="submit">
                    <i class="fa-solid fa-magnifying-glass"></i>
                    <span class="ms-1">Search</span>
                </button>

            </form>

            <div class="navbar-nav ms-auto align-items-center">

                <a class="nav-link fw-semibold" href="/listings/new">
                    List Your Home
                </a>

                <% if(!currUser){ %>

                    <a class="nav-link fw-semibold" href="/signup">
                        Sign Up
                    </a>

                    <a class="btn btn-danger rounded-pill px-3 ms-2" href="/login">
                        Login
                    </a>

                <% } %>

                <% if(currUser){ %>

                    <a class="nav-link fw-semibold" href="/logout">
                        Logout
                    </a>

                <% } %>

            </div>

        </div>
    </div>
</nav>

