<% layout("layouts/boilerplate") %>

<style>
.hero-img{
    height:500px;
    object-fit:cover;
    border-radius:24px;
}

.info-card,
.booking-card,
.review-card{
    border:none;
    border-radius:22px;
    box-shadow:0 8px 30px rgba(0,0,0,0.06);
}

.booking-card{
    position:sticky;
    top:90px;
}

.price-big{
    font-size:28px;
    font-weight:700;
}

.meta{
    color:#666;
}

.section-title{
    font-weight:700;
    margin-bottom:15px;
}

.review-stars{
    color:#ff385c;
    font-weight:600;
}

.host-badge{
    background:#f8f9fa;
    padding:10px 14px;
    border-radius:14px;
    display:inline-block;
}

textarea{
    resize:none;
}
</style>

<div class="container py-4">

    <!-- Title -->
    <h2 class="fw-bold mb-3"><%= listing.title %></h2>

    <!-- Image -->
    <img
        src="<%= listing.image.url %>"
        class="w-100 hero-img mb-4"
        alt="listing-image"
    >

    <div class="row g-4">

        <!-- LEFT CONTENT -->
        <div class="col-lg-8">

            <div class="card info-card p-4 mb-4">

                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">

                    <div>
                        <h4 class="mb-1"><%= listing.location %>, <%= listing.country %></h4>
                        <div class="meta">
                            ⭐
                            <%= listing.reviews.length
                            ? (listing.reviews.reduce((sum, review) => sum + review.rating, 0) / listing.reviews.length).toFixed(1)
                            : "New" %>
                            · <%= listing.reviews.length %> reviews
                        </div>
                    </div>

                    <div class="host-badge">
Hosted by <b><%= listing.owner?.username || "Unknown Host" %></b>                    </div>

                </div>

                <hr>

                <h5 class="section-title">About this place</h5>

                <p class="mb-0">
                    <%= listing.description %>
                </p>

            </div>

            <!-- Review Form -->
            <% if(currUser){ %>

            <div class="card info-card p-4 mb-4">

                <h5 class="section-title">Leave a Review</h5>

                <form
                    action="/listings/<%= listing._id %>/reviews"
                    method="POST"
                    class="needs-validation"
                    novalidate
                >

                    <div class="mb-3">
                        <label class="form-label">Rating</label>

                        <select class="form-select" name="review[rating]" required>
                            <option value="">Choose Rating</option>
                            <option value="5">⭐⭐⭐⭐⭐ Excellent</option>
                            <option value="4">⭐⭐⭐⭐ Very Good</option>
                            <option value="3">⭐⭐⭐ Good</option>
                            <option value="2">⭐⭐ Fair</option>
                            <option value="1">⭐ Poor</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Comment</label>

                        <textarea
                            class="form-control"
                            rows="4"
                            name="review[comment]"
                            required
                        ></textarea>
                    </div>

                    <button class="btn btn-danger px-4 rounded-pill">
                        Submit Review
                    </button>

                </form>

            </div>

            <% } %>

            <!-- Reviews -->
            <div class="card info-card p-4">

                <h5 class="section-title">Guest Reviews</h5>

                <div class="row g-3">

                    <% for(let review of listing.reviews){ %>

                    <div class="col-md-6">

                        <div class="card review-card h-100 p-3">

                            <div class="fw-bold mb-2">
                                @<%= review.author.username %>
                            </div>

                            <div class="review-stars mb-2">
                                ⭐ <%= review.rating %>/5
                            </div>

                            <div class="text-muted">
                                <%= review.comment %>
                            </div>

                            <% if(currUser && review.author._id.equals(currUser._id)){ %>

                            <form
                                class="mt-3"
                                method="POST"
                                action="/listings/<%=listing._id%>/reviews/<%=review._id%>?_method=DELETE"
                            >
                                <button class="btn btn-sm btn-outline-dark">
                                    Delete
                                </button>
                            </form>

                            <% } %>

                        </div>

                    </div>

                    <% } %>

                </div>

            </div>

        </div>

        <!-- RIGHT BOOKING CARD -->
<div class="col-lg-4">

    <div class="card booking-card p-4">

        <div class="price-big mb-3">
            ₹ <%= listing.price.toLocaleString("en-IN") %>
            <span class="fs-6 fw-normal">/ night</span>
        </div>

        <div class="mb-3">
            <label class="form-label">Check-in</label>
            <input type="date" class="form-control">
        </div>

        <div class="mb-3">
            <label class="form-label">Check-out</label>
            <input type="date" class="form-control">
        </div>

        <div class="mb-3">
            <label class="form-label">Guests</label>
            <select class="form-select">
                <option>1 Guest</option>
                <option>2 Guests</option>
                <option>3 Guests</option>
                <option>4 Guests</option>
            </select>
        </div>

        <!-- ========================= -->
        <!-- 🚀 BOOKING BUTTON LOGIC -->
        <!-- ========================= -->

        <% if(listing.isBooked){ %>

            <button class="btn btn-success w-100 rounded-pill py-2" disabled>
                Reserved ✔
            </button>

        <% } else { %>

            <form action="/listings/<%= listing._id %>/book" method="POST">
                <button class="btn btn-danger w-100 rounded-pill py-2">
                    Reserve Now
                </button>
            </form>

        <% } %>

<% if(currUser && listing.owner && listing.owner._id && currUser._id && listing.owner._id.equals(currUser._id)){ %>
        <hr>

        <a href="/listings/<%=listing._id%>/edit"
            class="btn btn-outline-dark w-100 mb-2 rounded-pill">
            Edit Listing
        </a>

        <form method="POST" action="/listings/<%=listing._id%>?_method=DELETE">
            <button class="btn btn-dark w-100 rounded-pill">
                Delete Listing
            </button>
        </form>

        <% } %>

    </div>

</div>